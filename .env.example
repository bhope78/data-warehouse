# ===========================================================================
# CATT Data Warehouse — Environment Configuration
# Copy to .env and fill in all values
# ===========================================================================

# Azure AD — App registration with Sites.Read.All (Application) permission
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SharePoint site URL — site ID and list IDs are resolved at runtime
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/YourSite

# AWS credentials (or use IAM role / AWS CLI profile instead)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2

# S3 bucket for raw extracts and Glue scripts
S3_BUCKET_NAME=catt-pipeline-data

# Redshift Serverless (used by setup script and Glue jobs)
REDSHIFT_WORKGROUP=catt-workgroup
REDSHIFT_DATABASE=dev
REDSHIFT_SCHEMA=catt
REDSHIFT_ADMIN_USER=cattadmin
